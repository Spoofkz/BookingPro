DATABASE_URL="file:./prisma/dev.db"
ALLOW_DEMO_AUTH="false"
OTP_STATIC_TEST_CODE="8888"

# Emergency kill switches (PRD #24 release readiness)
# Set to "true" to disable server-side feature flows during incidents/rollback mitigation.
RELEASE_DISABLE_HOLDS="false"
RELEASE_DISABLE_RESCHEDULE="false"
RELEASE_DISABLE_PROMOS="false"
RELEASE_DISABLE_MEMBERSHIP_APPLY="false"
