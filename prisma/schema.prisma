  rescheduleIntentsAsNew RescheduleIntent[] @relation("RescheduleNewSlot")

  @@unique([clubId, startAtUtc, endAtUtc])
  @@index([clubId, localDate])
  @@index([clubId, startAtUtc])
  @@index([clubId, status, startAtUtc])
}

model Hold {
  id               String     @id @default(cuid())
  clubId           String
  slotId           String
  seatId           String
  ownerUserId      String?
  orderId          String?
