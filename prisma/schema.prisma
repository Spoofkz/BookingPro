  payment         Payment?                  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdByUser   User?                     @relation("MembershipTxActor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clubId, txType, createdAt])
  @@index([entitlementId, createdAt])
  @@index([customerId, createdAt])
  @@index([userId, createdAt])
  @@index([bookingId, txType])
}
