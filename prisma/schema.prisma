model MembershipTransaction {
  id              String                    @id @default(cuid())
  clubId          String
  entitlementId   String
  planId          String?
  customerId      String?
  userId          String?
  bookingId       Int?
  paymentId       Int?
  txType          MembershipTransactionType
  amountDelta     Int                       @default(0)
  minutesDelta    Int                       @default(0)
  sessionsDelta   Int                       @default(0)
