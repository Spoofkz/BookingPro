  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  club             Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  slot             Slot       @relation(fields: [slotId], references: [id], onDelete: Cascade)
  order            Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItems       OrderItem[]
  ownerUser        User?      @relation("HoldOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  canceledByUser   User?      @relation("HoldCanceledBy", fields: [canceledByUserId], references: [id], onDelete: SetNull)

  @@index([clubId, slotId])
  @@index([clubId, slotId, seatId])
  @@index([clubId, slotId, seatId, purpose])
  @@index([clubId, status, expiresAtUtc])
  @@index([orderId])
}

model RescheduleIntent {
  id                 String                     @id @default(cuid())
  clubId             String
  bookingId          Int
  oldSlotId          String?
  oldSeatId          String?
  newSlotId          String
  newSeatId          String
  newRoomId          Int?
  packageId          String?
  lockHoldId         String?                    @unique
  status             RescheduleIntentStatus     @default(ACTIVE)
  expiresAtUtc       DateTime
  createdByUserId    String
  createdByRole      RescheduleActorRole
  reason             String?
  policyOverrideUsed Boolean                    @default(false)
  oldPriceTotal      Int
  newPriceTotal      Int
  delta              Int
  requiredAction     RescheduleRequiredAction   @default(NONE)
  paymentStatus      ReschedulePaymentStatus    @default(NONE)
  settlementStatus   RescheduleSettlementStatus @default(NONE)
  newQuoteSnapshotJson String
  confirmedAt        DateTime?
  canceledAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  club               Club                       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  booking            Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  oldSlot            Slot?                      @relation("RescheduleOldSlot", fields: [oldSlotId], references: [id], onDelete: SetNull)
  newSlot            Slot                       @relation("RescheduleNewSlot", fields: [newSlotId], references: [id], onDelete: Cascade)
  createdByUser      User                       @relation("RescheduleIntentCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)
  lockHold           Hold?                      @relation("RescheduleIntentLockHold", fields: [lockHoldId], references: [id], onDelete: SetNull)

  @@index([clubId, bookingId, status])
  @@index([clubId, newSlotId, newSeatId, status])
  @@index([clubId, expiresAtUtc, status])
  @@index([createdByUserId, createdAt])
}

